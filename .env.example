# DeepSeek API Key — 用于 AI 翻译功能
# 在 https://platform.deepseek.com/api_keys 获取你的 API Key
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# OpenAI API Key — 用于 GPT 模型
# 在 https://platform.openai.com/api-keys 获取你的 API Key
OPENAI_API_KEY=your_openai_api_key_here

# Gemini API Key — 用于 Google Gemini 模型
# 在 https://aistudio.google.com/apikey 获取你的 API Key
GEMINI_API_KEY=your_gemini_api_key_here

# Google Cloud Vision API Key — 用于 OCR 文字识别
# 在 https://console.cloud.google.com/apis/credentials 获取你的 API Key
GOOGLE_VISION_API_KEY=your_google_vision_api_key_here